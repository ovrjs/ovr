{
	"name": "ovr",
	"description": "The Streaming Framework",
	"version": "6.2.3",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ovrjs/ovr.git"
	},
	"author": {
		"name": "Ross Robino",
		"url": "https://robino.dev"
	},
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"exports": {
		"./package.json": {
			"default": "./package.json"
		},
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./jsx-runtime": {
			"types": "./dist/jsx-runtime.d.ts",
			"default": "./dist/jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./dist/jsx-dev-runtime.d.ts",
			"default": "./dist/jsx-dev-runtime.js"
		}
	},
	"files": [
		"dist",
		"src",
		"!src/**/*.test.ts"
	],
	"scripts": {
		"check": "tsc",
		"dev": "tsc --watch -p tsconfig.build.json",
		"build": "tsc -p tsconfig.build.json && cp ../../LICENSE.md dist"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0"
	}
}
