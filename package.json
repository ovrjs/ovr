{
	"name": "ovr-monorepo",
	"private": true,
	"version": "0.0.0",
	"license": "MIT",
	"packageManager": "npm@11.12.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ovrjs/ovr.git"
	},
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"check": "turbo check",
		"test": "vitest run",
		"test:dev": "vitest",
		"bench": "NODE_OPTIONS='--expose-gc' vitest bench",
		"build": "turbo build",
		"format": "prettier --write .",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "npm run build && changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@robino/prettier": "^2.0.3",
		"@robino/tsconfig": "^2.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.8.20",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	}
}
